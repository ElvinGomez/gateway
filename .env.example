# Origins for each microservice (https only, no trailing slash).
# Set these in Vercel: Project → Settings → Environment Variables.
# Use Production values for production deploys; use Preview (or branch-specific)
# values when you want the gateway preview to hit preview backends.
#
# Root directory for this Vercel project must be `gateway/` (monorepo: set in
# Project → Settings → General → Root Directory).

CDN_ORIGIN=https://your-cdn.vercel.app
CONFIG_ORIGIN=https://your-config.vercel.app
POST_ORIGIN=https://your-post.vercel.app
SPOTS_ORIGIN=https://your-spots.vercel.app
STORIES_ORIGIN=https://your-stories.vercel.app
USER_MANAGEMENT_ORIGIN=https://your-users.vercel.app
