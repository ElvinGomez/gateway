{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/health",
      "dest": "/api/health"
    },
    {
      "src": "^/file(?=/|$)(.*)$",
      "dest": "${CDN_ORIGIN}/file$1",
      "env": ["CDN_ORIGIN"]
    },
    {
      "src": "^/(config|internal)(?=/|$)(.*)$",
      "dest": "${CONFIG_ORIGIN}/$1$2",
      "env": ["CONFIG_ORIGIN"]
    },
    {
      "src": "^/feedback(?=/|$)(.*)$",
      "dest": "${FEEDBACK_ORIGIN}/feedback$1",
      "env": ["FEEDBACK_ORIGIN"]
    },
    {
      "src": "^/posts(?=/|$)(.*)$",
      "dest": "${POST_ORIGIN}/posts$1",
      "env": ["POST_ORIGIN"]
    },
    {
      "src": "^/stories(?=/|$)(.*)$",
      "dest": "${STORIES_ORIGIN}/stories$1",
      "env": ["STORIES_ORIGIN"]
    },
    {
      "src": "^/users(?=/|$)(.*)$",
      "dest": "${USER_MANAGEMENT_ORIGIN}/users$1",
      "env": ["USER_MANAGEMENT_ORIGIN"]
    },
    {
      "src": "^/spots(?=/|$)(.*)$",
      "dest": "${SPOTS_ORIGIN}/spots$1",
      "env": ["SPOTS_ORIGIN"]
    },
    {
      "src": "^/spot(?=/|$)(.*)$",
      "dest": "${SPOTS_ORIGIN}/spot$1",
      "env": ["SPOTS_ORIGIN"]
    },
    {
      "src": "^/reviews(?=/|$)(.*)$",
      "dest": "${SPOTS_ORIGIN}/reviews$1",
      "env": ["SPOTS_ORIGIN"]
    },
    {
      "src": "^/review(?=/|$)(.*)$",
      "dest": "${SPOTS_ORIGIN}/review$1",
      "env": ["SPOTS_ORIGIN"]
    }
  ]
}
